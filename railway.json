{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPaths": [
      "src/**",
      "package.json",
      "tsconfig.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 15,
    "restartPolicyType": "ON_FAILURE"
  }
}
