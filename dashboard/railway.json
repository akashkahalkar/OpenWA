{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPaths": [
      "src/**",
      "package.json",
      "vite.config.ts",
      "nginx.conf"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE"
  }
}
